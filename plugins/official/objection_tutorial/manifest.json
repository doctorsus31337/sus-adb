{
  "plugin_id": "susadb.objection-tutorial",
  "name": "Objection Assistant",
  "version": "1.1.0",
  "description": "A focused local Objection target, connection-plan, session, command-preview, troubleshooting, history, reference, and learning assistant.",
  "author": "SUS-ADB",
  "license": "MIT",
  "minimum_sus_adb_version": "1.0.0",
  "supported_platforms": ["linux", "windows"],
  "entry_point": "plugin.py:Plugin",
  "plugin_api_version": "1.0",
  "requested_capabilities": ["read-selected-device", "read-selected-target"],
  "optional_dependencies": [],
  "required_external_tools": [],
  "contributed_components": [
    {
      "contribution_id": "objection-assistant.panel",
      "contribution_type": "pentest-panel",
      "title": "Objection Assistant",
      "factory": "panel_spec",
      "metadata": {
        "ui_mode": "window",
        "singleton": true,
        "workspace_kind": "objection-assistant",
        "default_width": 1180,
        "default_height": 780,
        "minimum_width": 900,
        "minimum_height": 650
      }
    },
    {
      "contribution_id": "objection-assistant.menu",
      "contribution_type": "menu-action",
      "title": "Open Objection Assistant",
      "metadata": {"target": "objection-assistant.panel"}
    },
    {
      "contribution_id": "objection-tutorial.course",
      "contribution_type": "learning-course",
      "title": "Objection Foundations",
      "factory": "course_spec",
      "metadata": {"category": "education", "synthetic_only": true}
    }
  ],
  "addon_ui": {"category": "instrumentation", "ui_mode": "window"},
  "trust_state": "untrusted",
  "enabled": false,
  "caution_text": "Opening performs no command, attach, spawn, bypass action, device change, terminal launch, or network action. Complete technical details remain available and every session start is explicit."
}
